# Claude Code + DeepSeek 环境变量配置参考
# 
# 注意：
# 1. 请勿将实际 API Key 存储在此文件中
# 2. 此文件仅用于参考，实际环境变量应通过 setup-claude-deepseek.ps1 脚本设置
# 3. .env 文件已在 .gitignore 中，但请谨慎处理
#
# 使用说明：
# - Windows 用户：运行 scripts/setup-claude-deepseek.ps1 脚本自动设置
# - 如需手动配置，参考下方变量值

# ========== Anthropic API 配置 ==========

# DeepSeek API 的 Anthropic 兼容端点
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 从 https://platform.deepseek.com/ 获取的 API Key
# 格式：sk-xxxxxxxxxx
ANTHROPIC_AUTH_TOKEN=sk-your-api-key-here

# ========== 模型配置 ==========

# 主模型（用于 claude 命令）
ANTHROPIC_MODEL=deepseek-v3

# Opus 模型（高级推理）
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v3

# Sonnet 模型（平衡型）
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v3

# Haiku 模型（快速、轻量）
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v3-flash

# ========== Claude Code 配置 ==========

# 子代理使用的模型
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v3-flash

# 代码生成的努力级别：low, medium, max
CLAUDE_CODE_EFFORT_LEVEL=max

# ========== 可选配置 ==========

# 是否启用调试模式（显示 API 请求/响应）
# DEBUG=true

# 自定义超时（单位：秒）
# ANTHROPIC_TIMEOUT=60
